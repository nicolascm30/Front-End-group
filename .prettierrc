{
    "plugins": [
        "prettier-plugin-astro",
        "prettier-plugin-tailwindcss"
    ],
    "overrides": [
        {
            "files": "*.astro",
            "options": {
                "parser": "astro"
            }
        }
    ],
    "tailwindStylesheet": "./src/styles/global.css",
    "tabWidth": 2,
    "printWidth": 150,
    "singleQuote": false,
    "trailingComma": "none",
    "semi": false,
    "endOfLine": "auto"
}