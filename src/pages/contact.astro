---
import Navegation from "@/components/navegation.astro"
import Layout from "../layouts/layout.astro"
import { ArrowRight, Mail, Users, LifeBuoy, X } from "@lucide/astro"
---

<Layout>
  <Navegation />

  <!-- HERO -->
  <section class="flex h-[90dvh] items-center justify-center bg-white px-6 py-16">
    <div class="flex h-full w-full max-w-[90%] flex-col items-center justify-between gap-10 md:flex-row">
      <div class="space-y-6">
        <h1 class="text-4xl leading-tight font-bold text-gray-900 2xl:text-6xl">
          Habla con nuestro<br />equipo de expertos
        </h1>
        <p class="max-w-sm text-sm text-gray-500 2xl:text-lg">
          ¿Tienes dudas sobre nuestros programas, precios o metodología? Escríbenos y te responderemos en menos de 24 horas.
        </p>
        <div class="flex gap-3">
          <a
            href="#contact-form"
            class="flex items-center gap-1 rounded-lg bg-[#1e2d5a] px-5 py-2.5 text-sm font-semibold whitespace-nowrap text-white transition hover:bg-[#16224a]"
          >
            Enviar mensaje <ArrowRight />
          </a>
          <a
            href="/#cursos"
            class="rounded-lg border border-gray-400 bg-[#E1E4ED] px-5 py-2.5 text-sm font-semibold whitespace-nowrap text-gray-700 transition hover:bg-gray-100"
          >
            Ver programas
          </a>
        </div>
      </div>
       <div class='relative aspect-square w-full max-w-lg'>
        <img
          src='/group_banner.png'
          width='300'
          height='400'
          alt='Clases de idiomas en línea en vivo'
          class='absolute bottom-0 left-0 max-w-100 rounded-lg object-cover shadow-lg'
        />
        <img
          src='/woman_banner.png'
          width='300'
          height='400'
          alt='Tutores nativos certificados'
          class='absolute top-0 right-0 max-w-100 rounded-lg border-4 border-white object-cover shadow-xl'
        />
      </div>
    </div>
  </section>

  <!-- SECCIÓN DE CONTACTO -->
  <section class="bg-[#F5F5F5] px-6 py-16">
    <div class="mx-auto grid max-w-5xl gap-10 md:grid-cols-[3fr_2fr]">
      <!-- Izquierda: Formulario -->
      <form id="contact-form" novalidate class="space-y-4 rounded-2xl border border-slate-200 bg-white p-8 shadow-sm">
        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-1">
            <label for="f-name" class="text-xs font-semibold text-gray-500">Nombre</label>
            <input
              id="f-name"
              type="text"
              placeholder="Tu nombre"
              class="w-full rounded-lg border border-gray-200 bg-[#F9FAFB] px-3 py-2 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-2 focus:ring-[#1e2d5a]/20 focus:outline-none"
            />
            <span id="err-name" class="hidden text-xs text-red-500">Ingresa tu nombre (mínimo 2 caracteres).</span>
          </div>
          <div class="space-y-1">
            <label for="f-email" class="text-xs font-semibold text-gray-500">Correo electrónico</label>
            <input
              id="f-email"
              type="email"
              placeholder="tu@correo.com"
              class="w-full rounded-lg border border-gray-200 bg-[#F9FAFB] px-3 py-2 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-2 focus:ring-[#1e2d5a]/20 focus:outline-none"
            />
            <span id="err-email" class="hidden text-xs text-red-500">Ingresa un correo electrónico válido.</span>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div class="space-y-1">
            <label for="f-phone" class="text-xs font-semibold text-gray-500">Teléfono</label>
            <input
              id="f-phone"
              type="text"
              inputmode="numeric"
              placeholder="(000) 000-0000"
              maxlength="14"
              class="w-full rounded-lg border border-gray-200 bg-[#F9FAFB] px-3 py-2 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-2 focus:ring-[#1e2d5a]/20 focus:outline-none"
            />
            <span id="err-phone" class="hidden text-xs text-red-500">Ingresa un número de teléfono válido de 10 dígitos.</span>
          </div>
          <div class="space-y-1">
            <label for="f-interest" class="text-xs font-semibold text-gray-500">¿Qué idioma te interesa?</label>
            <input
              id="f-interest"
              type="text"
              placeholder="Inglés, Español, Francés..."
              class="w-full rounded-lg border border-gray-200 bg-[#F9FAFB] px-3 py-2 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-2 focus:ring-[#1e2d5a]/20 focus:outline-none"
            />
          </div>
        </div>

        <div class="space-y-1">
          <label for="f-message" class="text-xs font-semibold text-gray-500">Mensaje</label>
          <textarea
            id="f-message"
            rows="5"
            placeholder="Escribe tu mensaje aquí..."
            class="w-full resize-none rounded-lg border border-gray-200 bg-[#F9FAFB] px-3 py-2 text-sm text-gray-800 placeholder:text-gray-400 focus:ring-2 focus:ring-[#1e2d5a]/20 focus:outline-none"
          ></textarea>
          <span id="err-message" class="hidden text-xs text-red-500">Por favor escribe un mensaje (mínimo 10 caracteres).</span>
        </div>

        <div class="flex items-center gap-4 pt-1">
          <button
            type="submit"
            class="flex items-center gap-2 rounded-lg bg-[#1e2d5a] px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-[#16224a]"
          >
            Enviar mensaje <ArrowRight class="size-4" />
          </button>
          <span id="form-success" class="hidden text-sm font-semibold text-green-600">¡Mensaje enviado con éxito!</span>
        </div>
      </form>

      <!-- Derecha: Info -->
      <div class="flex flex-col justify-center space-y-6">
        <div class="space-y-3">
          <h2 class="text-3xl leading-tight font-bold text-gray-900">
            ¿Cómo podemos<br />ayudarte?
          </h2>
          <p class="text-sm text-gray-500">Completa el formulario y nuestro equipo se pondrá en contacto contigo a la brevedad posible.</p>
        </div>

        <div id="contact-cards" class="space-y-3">
          <!-- Negocios -->
          <a href="mailto:negocios@linguaedge.com" class="contact-card flex items-center gap-3 rounded-xl border border-gray-200 bg-white p-4 transition hover:border-[#1e2d5a]/30 hover:shadow-sm">
            <div class="shrink-0 rounded-lg bg-[#F1F3F7] p-2">
              <Mail class="size-4 text-[#1e2d5a]" />
            </div>
            <div class="min-w-0">
              <p class="text-xs font-medium text-gray-400">Negocios</p>
              <p class="truncate text-sm font-semibold text-gray-800">negocios@linguaedge.com</p>
            </div>
            <button
              type="button"
              class="dismiss-btn ml-auto shrink-0 rounded-full p-1 text-gray-300 transition hover:bg-gray-100 hover:text-gray-500"
              aria-label="Cerrar"
              onclick="event.preventDefault(); event.stopPropagation(); this.closest('.contact-card').remove()"
            >
              <X class="size-3.5" />
            </button>
          </a>

          <!-- Alianzas -->
          <a href="mailto:alianzas@linguaedge.com" class="contact-card flex items-center gap-3 rounded-xl border border-gray-200 bg-white p-4 transition hover:border-[#1e2d5a]/30 hover:shadow-sm">
            <div class="shrink-0 rounded-lg bg-[#F1F3F7] p-2">
              <Users class="size-4 text-[#1e2d5a]" />
            </div>
            <div class="min-w-0">
              <p class="text-xs font-medium text-gray-400">Alianzas</p>
              <p class="truncate text-sm font-semibold text-gray-800">alianzas@linguaedge.com</p>
            </div>
            <button
              type="button"
              class="dismiss-btn ml-auto shrink-0 rounded-full p-1 text-gray-300 transition hover:bg-gray-100 hover:text-gray-500"
              aria-label="Cerrar"
              onclick="event.preventDefault(); event.stopPropagation(); this.closest('.contact-card').remove()"
            >
              <X class="size-3.5" />
            </button>
          </a>

          <!-- Soporte -->
          <a href="mailto:soporte@linguaedge.com" class="contact-card flex items-center gap-3 rounded-xl border border-gray-200 bg-white p-4 transition hover:border-[#1e2d5a]/30 hover:shadow-sm">
            <div class="shrink-0 rounded-lg bg-[#F1F3F7] p-2">
              <LifeBuoy class="size-4 text-[#1e2d5a]" />
            </div>
            <div class="min-w-0">
              <p class="text-xs font-medium text-gray-400">Soporte</p>
              <p class="truncate text-sm font-semibold text-gray-800">soporte@linguaedge.com</p>
            </div>
            <button
              type="button"
              class="dismiss-btn ml-auto shrink-0 rounded-full p-1 text-gray-300 transition hover:bg-gray-100 hover:text-gray-500"
              aria-label="Cerrar"
              onclick="event.preventDefault(); event.stopPropagation(); this.closest('.contact-card').remove()"
            >
              <X class="size-3.5" />
            </button>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="bg-[#F5F5F5] px-6 py-14">
    <div class="mx-auto max-w-2xl space-y-5 text-center">
      <h2 class="text-2xl font-bold text-gray-900">Recibe las últimas novedades y actualizaciones</h2>
      <p class="text-sm text-gray-500">Suscríbete a nuestro boletín para estar al tanto de nuevos cursos, metodologías y ofertas exclusivas.</p>
      <form id="newsletter-form" class="mx-auto flex max-w-md flex-col gap-3 sm:flex-row" novalidate>
        <div class="flex flex-1 flex-col gap-1">
          <input
            id="newsletter-email"
            type="email"
            placeholder="Ingresa tu correo electrónico"
            class="flex-1 rounded-lg border border-gray-300 bg-white px-4 py-2.5 text-sm focus:ring-2 focus:ring-[#1e2d5a]/30 focus:outline-none"
          />
          <span id="err-newsletter" class="hidden text-left text-xs text-red-500">Ingresa un correo electrónico válido.</span>
        </div>
        <div class="flex flex-col items-start gap-1">
          <button
            type="submit"
            class="rounded-lg bg-[#1e2d5a] px-5 py-2.5 text-sm font-semibold whitespace-nowrap text-white transition hover:bg-[#16224a]"
          >
            Suscribirme
          </button>
          <span id="newsletter-success" class="hidden text-xs font-semibold text-green-600">¡Suscrito con éxito!</span>
        </div>
      </form>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-gray-200 bg-[#F5F5F5] px-6 py-8">
    <div class="mx-auto flex max-w-5xl flex-col items-center gap-5">
      <div class="flex gap-4">
        <a href="https://x.com" target="_blank" rel="noopener noreferrer" aria-label="X (Twitter)" class="rounded-lg bg-[#F1F3F7] p-2 transition hover:bg-gray-200">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1e2d5a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4l16 16M4 20 20 4"></path>
          </svg>
        </a>
        <a href="https://facebook.com" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="rounded-lg bg-[#F1F3F7] p-2 transition hover:bg-gray-200">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1e2d5a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
          </svg>
        </a>
        <a href="https://instagram.com" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="rounded-lg bg-[#F1F3F7] p-2 transition hover:bg-gray-200">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1e2d5a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
          </svg>
        </a>
        <a href="https://linkedin.com" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn" class="rounded-lg bg-[#F1F3F7] p-2 transition hover:bg-gray-200">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1e2d5a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
            <rect width="4" height="12" x="2" y="9"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
        <a href="https://youtube.com" target="_blank" rel="noopener noreferrer" aria-label="YouTube" class="rounded-lg bg-[#F1F3F7] p-2 transition hover:bg-gray-200">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1e2d5a" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"></path>
            <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"></polygon>
          </svg>
        </a>
      </div>
      <p class="text-xs text-gray-400">Copyright © 2025 LinguaEdge — Todos los derechos reservados.</p>
      <div class="flex gap-4 text-xs text-gray-500">
        <button data-policy="terms" class="hover:underline">Términos y Condiciones</button>
        <span class="text-gray-300">|</span>
        <button data-policy="privacy" class="hover:underline">Política de Privacidad</button>
      </div>
    </div>
  </footer>
</Layout>

<script>
  // ── TOAST ──────────────────────────────────────────────────────────────────

  function showToast(msg: string): void {
    const toast = document.createElement("div")
    toast.className =
      "fixed bottom-6 left-1/2 z-[200] -translate-x-1/2 rounded-xl bg-[#1e2d5a] px-5 py-3 text-sm font-medium text-white shadow-xl transition-opacity"
    toast.textContent = msg
    document.body.appendChild(toast)
    setTimeout(() => {
      toast.style.opacity = "0"
      setTimeout(() => toast.remove(), 300)
    }, 2700)
  }

  // ── TÉRMINOS Y PRIVACIDAD ──────────────────────────────────────────────────

  document.querySelectorAll<HTMLButtonElement>("[data-policy]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const isTerms = btn.dataset.policy === "terms"
      showToast(isTerms ? "Términos y Condiciones próximamente disponibles." : "Política de Privacidad próximamente disponible.")
    })
  })

  // ── HELPERS ───────────────────────────────────────────────────────────────

  function isValidEmail(v: string): boolean {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(v.trim())
  }

  function isValidPhone(v: string): boolean {
    return v.replace(/\D/g, "").length === 10
  }

  function setError(inputId: string, spanId: string, hasError: boolean): void {
    const el = document.getElementById(inputId) as HTMLInputElement | HTMLTextAreaElement | null
    const span = document.getElementById(spanId)
    if (!el || !span) return
    if (hasError) {
      el.classList.add("border-red-400")
      el.classList.remove("border-gray-200")
      span.classList.remove("hidden")
    } else {
      el.classList.remove("border-red-400")
      el.classList.add("border-gray-200")
      span.classList.add("hidden")
    }
  }

  const fieldMap: Record<string, string> = {
    "f-name": "err-name",
    "f-email": "err-email",
    "f-message": "err-message",
    "newsletter-email": "err-newsletter",
  }
  Object.entries(fieldMap).forEach(([inputId, spanId]) => {
    document.getElementById(inputId)?.addEventListener("input", () => setError(inputId, spanId, false))
  })

  // Formato automático de teléfono → (xxx) xxx-xxxx
  const phoneInput = document.getElementById("f-phone") as HTMLInputElement | null
  phoneInput?.addEventListener("input", () => {
    setError("f-phone", "err-phone", false)
    const digits = phoneInput.value.replace(/\D/g, "").slice(0, 10)
    if (digits.length === 0) {
      phoneInput.value = ""
      return
    }
    if (digits.length <= 3) {
      phoneInput.value = `(${digits}`
      return
    }
    if (digits.length <= 6) {
      phoneInput.value = `(${digits.slice(0, 3)}) ${digits.slice(3)}`
      return
    }
    phoneInput.value = `(${digits.slice(0, 3)}) ${digits.slice(3, 6)}-${digits.slice(6)}`
  })

  // ── FORMULARIO DE CONTACTO ────────────────────────────────────────────────

  document.getElementById("contact-form")?.addEventListener("submit", (e) => {
    e.preventDefault()

    const name = (document.getElementById("f-name") as HTMLInputElement).value.trim()
    const email = (document.getElementById("f-email") as HTMLInputElement).value.trim()
    const phone = (document.getElementById("f-phone") as HTMLInputElement).value.trim()
    const message = (document.getElementById("f-message") as HTMLTextAreaElement).value.trim()

    const nameErr = name.length < 2
    const emailErr = !isValidEmail(email)
    const phoneErr = phone.length > 0 && !isValidPhone(phone)
    const messageErr = message.length < 10

    setError("f-name", "err-name", nameErr)
    setError("f-email", "err-email", emailErr)
    setError("f-phone", "err-phone", phoneErr)
    setError("f-message", "err-message", messageErr)

    if (nameErr || emailErr || phoneErr || messageErr) return

    const success = document.getElementById("form-success")
    if (success) {
      success.classList.remove("hidden")
      setTimeout(() => success.classList.add("hidden"), 3000)
    }
    ;(e.target as HTMLFormElement).reset()
    Object.keys(fieldMap).forEach((id) => setError(id, fieldMap[id]!, false))
    setError("f-phone", "err-phone", false)
  })

  // ── NEWSLETTER ────────────────────────────────────────────────────────────

  document.getElementById("newsletter-form")?.addEventListener("submit", (e) => {
    e.preventDefault()
    const email = (document.getElementById("newsletter-email") as HTMLInputElement).value.trim()
    const hasError = !isValidEmail(email)
    setError("newsletter-email", "err-newsletter", hasError)
    if (hasError) return

    const success = document.getElementById("newsletter-success")
    if (success) {
      success.classList.remove("hidden")
      setTimeout(() => success.classList.add("hidden"), 3000)
    }
    ;(e.target as HTMLFormElement).reset()
    setError("newsletter-email", "err-newsletter", false)
  })
</script>
