---
import Navegation from "@/components/navegation.astro"
import Layout from "../layouts/layout.astro"

import { ArrowRight, Mail, Phone } from "@lucide/astro"
import servicesData from "../data/services.json"

const { categories, items: services } = servicesData
---

<Layout>
  <Navegation />

  <section class="flex h-[90dvh] items-center justify-center bg-white px-6 py-16">
    <div class="flex h-full w-full max-w-[90%] flex-col items-center justify-between gap-10 md:flex-row">
      <div class="space-y-6">
        <h1 class="text-4xl leading-tight font-bold text-gray-900 2xl:text-6xl">
          Discover the key to<br />grow your business
        </h1>
        <p class="max-w-sm text-sm text-gray-500 2xl:text-lg">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore et dolore magna aliqua.
        </p>
        <div class="flex gap-3">
          <a
            href="#"
            class="flex items-center gap-1 rounded-lg bg-[#1e2d5a] px-5 py-2.5 text-sm font-semibold text-nowrap whitespace-nowrap text-white transition hover:bg-[#16224a]"
          >
            Get started <ArrowRight /></a
          >
          <a
            href="#"
            class="rounded-lg border border-gray-400 bg-[#E1E4ED] px-5 py-2.5 text-sm font-semibold text-nowrap whitespace-nowrap text-gray-700 transition hover:bg-gray-100"
          >
            Learn more
          </a>
        </div>
      </div>
      <div class="relative aspect-square w-full max-w-lg">
        <img
          src="https://placehold.co/300x400"
          alt="Illustration of business growth"
          class="absolute bottom-0 left-0 max-w-100 rounded-lg object-cover shadow-lg"
        />
        <img
          src="https://placehold.co/300x400"
          alt="Illustration of business growth"
          class="absolute top-0 right-0 max-w-100 rounded-lg object-cover shadow-lg"
        />
      </div>
    </div>
  </section>

  <section class="bg-[#F5F5F5] px-6 py-16">
    <div class="mx-auto max-w-5xl">
      <div class="mb-8 space-y-3 text-center">
        <h2 class="text-3xl font-bold text-gray-900">Highly effective solutions</h2>
        <p class="mx-auto max-w-md text-sm text-gray-500">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris.
        </p>
      </div>

      <div class="mb-8 flex justify-center gap-8">
        {
          categories.map((cat, i) => (
            <button
              class={`pb-1 text-xs font-semibold transition ${i === 0 ? "border-b-2 border-gray-800 text-gray-900" : "text-gray-400 hover:text-gray-600"}`}
            >
              {cat}
            </button>
          ))
        }
      </div>

      <div class="grid grid-cols-2 gap-4 md:grid-cols-4">
        {
          services.map((service) => (
            <div class="relative overflow-hidden rounded-xl" style="background: linear-gradient(145deg, #1e2d5a 0%, #3a4f8a 100%);">
              <img src={service.image} alt={service.alt} />
              <div class="absolute inset-0 bg-linear-to-b from-[#1e2d5a] to-transparent p-8 text-white">
                <span class="text-xs font-medium">{service.category}</span>
                <p class="text-xl font-bold">{service.title}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <section class="bg-white px-6 pt-16">
    <div class="mx-auto max-w-2xl space-y-6 shadow-md">
      <div class="space-y-2 text-center">
        <h2 class="text-3xl font-bold text-[#6D758F]">Let us know<br />what you think!</h2>
        <p class="mx-auto max-w-sm text-sm font-semibold text-gray-500">
          Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed do eiusmod tempor incididunt ut labore.
        </p>
      </div>
      <form class="space-y-4 overflow-hidden rounded-xl border border-slate-200 p-8">
        <div class="space-y-1">
          <label class="text-xs font-semibold text-gray-600">First Name</label>
          <input
            type="text"
            placeholder="First name"
            class="w-full rounded border border-gray-300 bg-white px-3 py-2 text-sm focus:ring-2 focus:ring-[#1e2d5a]/30 focus:outline-none"
          />
        </div>
        <div class="space-y-1">
          <label class="text-xs font-semibold text-gray-600">Email</label>
          <input
            type="email"
            placeholder="your@email.com"
            class="w-full rounded border border-gray-300 bg-white px-3 py-2 text-sm focus:ring-2 focus:ring-[#1e2d5a]/30 focus:outline-none"
          />
        </div>
        <div class="space-y-1">
          <label class="text-xs font-semibold text-gray-600">Phone</label>
          <input
            type="tel"
            placeholder="+1 (000) 000-0000"
            class="w-full rounded border border-gray-300 bg-white px-3 py-2 text-sm focus:ring-2 focus:ring-[#1e2d5a]/30 focus:outline-none"
          />
        </div>
        <button type="submit" class="rounded bg-[#1e2d5a] px-6 py-2.5 text-sm font-semibold text-white transition hover:bg-[#16224a]">
          Send message
        </button>
      </form>
    </div>
  </section>

  <section class="mx-auto max-w-5xl bg-white px-6 py-14">
    <div class="mx-auto flex-col items-center gap-10 md:flex-row">
      <div class="flex-1 space-y-4 text-center">
        <h2 class="text-2xl font-bold text-gray-900">Want to reach us<br />directly?</h2>
        <p class="mx-auto max-w-xs text-sm text-gray-500">Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p>
      </div>
      <div class="mx-auto flex max-w-2xl flex-1 flex-col gap-4 sm:flex-row">
        <div class="flex flex-1 items-start gap-3 rounded-xl border border-gray-200 p-5">
          <div class="rounded-lg bg-[#F1F3F7] p-2">
            <Mail />
          </div>
          <div>
            <p class="text-xs font-medium text-gray-400">Email</p>
            <p class="text-sm font-semibold text-gray-800">hello@yourcompany.com</p>
          </div>
        </div>
        <div class="flex flex-1 items-start gap-3 rounded-xl border border-gray-200 p-5">
          <div class="rounded-lg bg-[#F1F3F7] p-2">
            <Phone />
          </div>
          <div>
            <p class="text-xs font-medium text-gray-400">Phone</p>
            <p class="text-sm font-semibold text-gray-800">+1 (987) 654-3210</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-[#F5F5F5] px-6 py-14">
    <div class="mx-auto max-w-2xl space-y-5 text-center">
      <h2 class="text-2xl font-bold text-gray-900">Get the latest news and updates</h2>
      <p class="text-sm text-gray-500">Subscribe to our newsletter and never miss an update. We promise no spam.</p>
      <form class="mx-auto flex max-w-md flex-col gap-3 sm:flex-row">
        <input
          type="email"
          placeholder="Enter your email"
          class="flex-1 rounded border border-gray-300 bg-white px-4 py-2.5 text-sm focus:ring-2 focus:ring-[#1e2d5a]/30 focus:outline-none"
        />
        <button
          type="submit"
          class="rounded bg-[#1e2d5a] px-5 py-2.5 text-sm font-semibold whitespace-nowrap text-white transition hover:bg-[#16224a]"
        >
          Subscribe
        </button>
      </form>
    </div>
  </section>

  <footer class="border-t border-gray-200 bg-[#F5F5F5] px-6 py-8">
    <div class="mx-auto flex max-w-5xl flex-col items-center gap-5">
      <div class="flex gap-4">
        <a href="#" class="rounded-lg bg-[#F1F3F7] p-2 transition hover:bg-gray-200">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#1e2d5a"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M4 4l16 16M4 20 20 4"></path>
          </svg>
        </a>
        <a href="#" class="rounded-lg bg-[#F1F3F7] p-2 transition hover:bg-gray-200">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#1e2d5a"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"></path>
          </svg>
        </a>
        <a href="#" class="rounded-lg bg-[#F1F3F7] p-2 transition hover:bg-gray-200">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#1e2d5a"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
          </svg>
        </a>
        <a href="#" class="rounded-lg bg-[#F1F3F7] p-2 transition hover:bg-gray-200">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#1e2d5a"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path>
            <rect width="4" height="12" x="2" y="9"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
        <!-- YouTube -->
        <a href="#" class="rounded-lg bg-[#F1F3F7] p-2 transition hover:bg-gray-200">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="#1e2d5a"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <path
              d="M22.54 6.42a2.78 2.78 0 0 0-1.95-1.96C18.88 4 12 4 12 4s-6.88 0-8.59.46a2.78 2.78 0 0 0-1.95 1.96A29 29 0 0 0 1 12a29 29 0 0 0 .46 5.58A2.78 2.78 0 0 0 3.41 19.6C5.12 20 12 20 12 20s6.88 0 8.59-.46a2.78 2.78 0 0 0 1.95-1.95A29 29 0 0 0 23 12a29 29 0 0 0-.46-5.58z"
            ></path>
            <polygon points="9.75 15.02 15.5 12 9.75 8.98 9.75 15.02"></polygon>
          </svg>
        </a>
      </div>

      <p class="text-xs text-gray-400">Copyright © 2025 Company — All rights reserved.</p>

      <div class="flex gap-4 text-xs text-gray-500">
        <a href="#" class="hover:underline">Terms and Conditions</a>
        <span class="text-gray-300">|</span>
        <a href="#" class="hover:underline">Privacy Policy</a>
      </div>
    </div>
  </footer>
</Layout>
